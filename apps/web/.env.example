# Vite carrega variables VITE_* des de:
#   - .env a l'arrel del monorepo (money-tracker/.env), i
#   - .env en aquesta carpeta (apps/web/.env) — aquestes sobreescriuen les de l'arrel.
#
# Backend API (JWT, Sheets proxy, passkeys). En desenvolupament:
#   - Omet VITE_API_URL: Vite fa proxy a http://127.0.0.1:3001 (mateix origen, sense CORS).
#   - O defineix URL directa (l’API ha de tenir CORS_ORIGIN amb el teu origen de Vite, p. ex. :5174).
# VITE_API_URL=http://localhost:3001

VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_SPREADSHEET_ID=your-google-sheet-id
VITE_SPREADSHEET_ID_2=your-google-sheet-id-2

VITE_MORTGAGE_END_YEAR=2055
VITE_MORTGAGE_END_MONTH=7
VITE_MORTGAGE_MONTHLY_PAYMENT=1000
VITE_OWNERSHIP_SHARE=0.5

VITE_LOGIN_EMAIL_01=user1@example.com
VITE_LOGIN_EMAIL_02=user2@example.com

# Optional: labels and emojis for the profile switcher (defaults: Olga / Andrea)
# VITE_PROFILE_PRIMARY_LABEL=Main
# VITE_PROFILE_SECONDARY_LABEL=Partner
# VITE_PROFILE_PRIMARY_EMOJI=👤
# VITE_PROFILE_SECONDARY_EMOJI=👤
