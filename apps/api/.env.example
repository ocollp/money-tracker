PORT=3001
HOST=0.0.0.0

# MongoDB (omit locally only if you skip auth). On Render use Atlas; any of these names works:
# MONGODB_URI | MONGODB_URL | DATABASE_URL
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=money_tracker

# Required when MONGODB_URI is set
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Google OAuth (required for authorization code flow)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Comma-separated origins, or * for dev (tighten in production)
CORS_ORIGIN=http://localhost:5173

# WebAuthn / passkeys (Face ID, Touch ID). Read only by the API — keep them on the server.
# RP ID = hostname of the page where the user opens the app (no scheme, no path).
# Local Vite default: leave unset or use localhost (matches defaults in webauthn.js).
# WEBAUTHN_RP_ID=localhost
#
# Origins = full base URL(s) of the frontend (scheme + host + port if not 443). Comma-separated.
# Must include every URL you use to open the app (e.g. both apex and www).
# WEBAUTHN_ORIGIN=http://localhost:5173
#
# Production example (uncomment and set your domain):
# WEBAUTHN_RP_ID=finances.example.com
# WEBAUTHN_ORIGIN=https://finances.example.com
