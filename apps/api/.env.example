PORT=3001
HOST=0.0.0.0

# MongoDB (omit to run API without DB; /auth/google returns 503)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=money_tracker

# Required when MONGODB_URI is set
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Comma-separated origins, or * for dev (tighten in production)
CORS_ORIGIN=http://localhost:5173
